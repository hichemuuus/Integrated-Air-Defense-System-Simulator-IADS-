{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IADS WebSocket Protocol",
  "description": "Server-to-client state push and client-to-server control messages",

  "definitions": {
    "Position": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2,
      "description": "[x, y] in meters"
    },
      "Track": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "vx": { "type": "number" },
          "vy": { "type": "number" },
          "altitude": { "type": "number" },
          "classification": { "type": "string", "enum": ["HOSTILE", "FRIENDLY", "INTERCEPTOR"] },
          "heading": { "type": "number" },
          "speed": { "type": "number" },
          "visible": { "type": "boolean" },
          "displayX": { "type": "number" },
          "displayY": { "type": "number" },
          "history": { "type": "array", "items": { "$ref": "#/definitions/Position" }, "maxItems": 50 },
          "targetId": { "type": "integer", "default": null },
          "trackType": { "type": "string", "enum": ["STANDARD", "JAMMER", "SWARM"], "default": "STANDARD" },
          "jammed": { "type": "boolean", "default": false },
          "groupId": { "type": "integer", "default": null }
        },
        "required": ["id", "x", "y", "vx", "vy", "altitude", "classification", "heading", "speed", "visible"]
      },
    "Explosion": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "radius": { "type": "number" },
        "alpha": { "type": "number" }
      }
    },
    "MissMarker": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "radius": { "type": "number" },
        "alpha": { "type": "number" }
      }
    },
    "RadarSite": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "sweepAngle": { "type": "number" }
      },
      "required": ["id", "x", "y", "sweepAngle"]
    },
    "Threat": {
      "type": "object",
      "properties": {
        "track_id": { "type": "integer" },
        "eta": { "type": "number" }
      },
      "required": ["track_id", "eta"]
    },
    "Event": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "time": { "type": "string", "pattern": "^\\d{2}:\\d{2}:\\d{2}$" },
        "type": { "type": "string", "enum": ["THREAT", "LAUNCH", "DESTROYED", "DETECTED", "JAMMER", "MISS", "INFO", "NO_INTERCEPTORS", "LEAKER"] },
        "message": { "type": "string" }
      },
      "required": ["id", "time", "type", "message"]
    }
  },

  "serverToClient": {
    "description": "JSON object pushed from server to client every ~16ms",
    "type": "object",
    "properties": {
      "simTime": { "type": "number" },
      "tracks": { "type": "array", "items": { "$ref": "#/definitions/Track" } },
      "interceptors": { "type": "array", "items": { "$ref": "#/definitions/Track" } },
      "explosions": { "type": "array", "items": { "$ref": "#/definitions/Explosion" } },
      "missMarkers": { "type": "array", "items": { "$ref": "#/definitions/MissMarker" } },
      "radarSites": { "type": "array", "items": { "$ref": "#/definitions/RadarSite" } },
      "threats": { "type": "array", "items": { "$ref": "#/definitions/Threat" } },
      "events": { "type": "array", "items": { "$ref": "#/definitions/Event" } },
      "running": { "type": "boolean" },
      "stats": { "type": "object", "properties": {
        "kills": { "type": "integer" },
        "misses": { "type": "integer" },
        "launched": { "type": "integer" },
        "leakers": { "type": "integer" },
        "threats_engaged": { "type": "array", "items": { "type": "integer" } },
        "inventory_remaining": { "type": "integer" }
      } }
    },
    "required": ["simTime", "tracks", "interceptors", "explosions", "radarSites", "threats", "events", "running"]
  },

  "clientToServer": {
    "description": "JSON object sent from client to server to control the simulation",
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": ["pause", "resume", "speed", "launch", "reset", "step"]
      },
      "payload": {
        "type": "object",
        "properties": {
          "speed": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 10.0,
            "description": "Speed multiplier (used with action='speed')"
          },
          "target_id": {
            "type": "integer",
            "description": "Track ID to launch interceptor at (used with action='launch')"
          }
        }
      }
    },
    "required": ["action"],
    "examples": [
      {"action": "speed", "payload": {"speed": 2.0}},
      {"action": "launch", "payload": {"target_id": 3}},
      {"action": "pause"},
      {"action": "resume"},
      {"action": "reset"},
      {"action": "step"}
    ]
  },

  "endpoints": {
    "ws": {
      "url": "ws://localhost:8000/ws/sim",
      "description": "WebSocket endpoint for simulation state streaming and control"
    },
    "rest": {
      "url": "http://localhost:8000/api/status",
      "method": "GET",
      "response": {"status": "online", "simulations": 0}
    }
  }
}
